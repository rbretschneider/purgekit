<UserControl x:Class="PurgeKit.UI.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:conv="clr-namespace:PurgeKit.UI.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:SafetyLevelToBrushConverter x:Key="SafetyToBrush" />
        <conv:SafetyLevelToTextConverter x:Key="SafetyToText" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />

        <!-- Shared card item template -->
        <DataTemplate x:Key="ScanCardTemplate">
            <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="6" Padding="14,12" Margin="0,0,0,6">
                <StackPanel>
                    <!-- Row 1: Safety dot + Name -->
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                 Fill="{Binding Safety, Converter={StaticResource SafetyToBrush}}" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- Row 2: Description (wraps fully) -->
                    <TextBlock Text="{Binding Description}" Opacity="0.55" Margin="16,4,0,0"
                               TextWrapping="Wrap" FontSize="11.5" LineHeight="16" />

                    <!-- Busy spinner -->
                    <StackPanel Orientation="Horizontal" Margin="16,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                        <ui:ProgressRing Width="12" Height="12" IsActive="{Binding IsBusy}" />
                        <TextBlock Text="{Binding BusyText}" Margin="6,0,0,0" FontSize="12" Opacity="0.8" />
                    </StackPanel>

                    <!-- Result text -->
                    <TextBlock Text="{Binding ResultText}" Margin="16,4,0,0" FontSize="12"
                               Foreground="{StaticResource SafetyGreenBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ResultText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Row 3: Size + Action buttons -->
                    <DockPanel Margin="16,8,0,0"
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <TextBlock Text="{Binding SizeText}" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center"
                                   DockPanel.Dock="Left" />

                        <!-- Action buttons on the right -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button Content="Compact" Command="{Binding CompactWslCommand}"
                                    Visibility="{Binding ShowCompactButton, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="10,4" Margin="0,0,4,0" FontSize="12" />
                            <Button Content="Prune" Command="{Binding DockerPruneCommand}"
                                    Visibility="{Binding ShowDockerPruneButton, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="10,4" Margin="0,0,4,0" FontSize="12" />
                            <Button Content="Git GC" Command="{Binding GitGcCommand}"
                                    Visibility="{Binding ShowGitGcButton, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="10,4" Margin="0,0,4,0" FontSize="12" />
                            <Button Content="View" Command="{Binding OpenFolderCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,4" Margin="0,0,4,0" FontSize="12" />
                            <Button Content="Delete" Command="{Binding DeleteCommand}"
                                    Visibility="{Binding ShowDeleteButton, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource DeleteButtonStyle}"
                                    Padding="10,4" FontSize="12"
                                    IsEnabled="{Binding IsDeleted, Converter={StaticResource InverseBool}}" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Scan Results" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusText}" Opacity="0.7" Margin="0,4,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="Clean All" Command="{Binding CleanAllSafeCommand}"
                    Style="{StaticResource AccentButtonStyle}" Padding="20,8" FontSize="13"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Visibility="{Binding SafeItems.Count, Converter={StaticResource CountToVis}}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBool}}" />
        </DockPanel>

        <!-- Progress -->
        <StackPanel Grid.Row="1" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
            <ui:ProgressBar IsIndeterminate="True" />
            <DockPanel Margin="0,4,0,0" Opacity="0.6">
                <TextBlock Text="{Binding ProgressPhase}" FontWeight="SemiBold" Margin="0,0,12,0" />
                <TextBlock Text="{Binding ProgressDetail}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </StackPanel>

        <!-- Two-column results -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- SAFE column -->
            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Safe to Clean" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource SafetyGreenBrush}" />
                    <TextBlock Text="{Binding SafeTotalText}" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SafeItems}"
                                  ItemTemplate="{StaticResource ScanCardTemplate}" />
                </ScrollViewer>
            </DockPanel>

            <!-- REVIEW column -->
            <DockPanel Grid.Column="2">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Needs Review" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource SafetyCautionBrush}" />
                    <TextBlock Text="{Binding ReviewTotalText}" FontSize="12" Opacity="0.6" Margin="0,2,0,0" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ReviewItems}"
                                  ItemTemplate="{StaticResource ScanCardTemplate}" />
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVis}}"
                    IsHitTestVisible="False">
            <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="48"
                       HorizontalAlignment="Center" Opacity="0.3" />
            <TextBlock Text="No scan results yet" FontSize="16" HorizontalAlignment="Center" Opacity="0.5" Margin="0,8,0,0" />
            <TextBlock Text="Click Scan All in the sidebar to find temp files, caches, GPU drivers, Docker, dev tools, and large files"
                       FontSize="13" HorizontalAlignment="Center" Opacity="0.4" Margin="0,4,0,0" TextWrapping="Wrap"
                       MaxWidth="400" TextAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
