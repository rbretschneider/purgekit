<UserControl x:Class="PurgeKit.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:conv="clr-namespace:PurgeKit.UI.Converters">

    <UserControl.Resources>
        <conv:StringMatchToBoolConverter x:Key="StringMatchToBool" />
    </UserControl.Resources>

    <ScrollViewer Margin="24,20" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600">
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,24" />

            <!-- Theme -->
            <TextBlock Text="Theme" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <RadioButton Content="Dark" Margin="0,0,16,0"
                             IsChecked="{Binding Theme, Converter={StaticResource StringMatchToBool}, ConverterParameter=Dark}" />
                <RadioButton Content="Light" Margin="0,0,16,0"
                             IsChecked="{Binding Theme, Converter={StaticResource StringMatchToBool}, ConverterParameter=Light}" />
                <RadioButton Content="System"
                             IsChecked="{Binding Theme, Converter={StaticResource StringMatchToBool}, ConverterParameter=System}" />
            </StackPanel>

            <!-- Delete Mode -->
            <TextBlock Text="Delete Mode" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <StackPanel Margin="0,0,0,4">
                <ui:ToggleSwitch IsOn="{Binding UseRecycleBin}" Header="Send deleted files to Recycle Bin" />
            </StackPanel>
            <TextBlock Text="When disabled (default), files are permanently deleted. This is faster and avoids filling the Recycle Bin."
                       Opacity="0.6" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,24" />

            <!-- Deep Scan Settings -->
            <TextBlock Text="Deep Scan" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

            <TextBlock Text="{Binding MinFileAgeDays, StringFormat='Minimum file age for AppData flagging: {0} days'}" Margin="0,0,0,4" />
            <Slider Value="{Binding MinFileAgeDays}" Minimum="30" Maximum="365" Width="400"
                    HorizontalAlignment="Left" TickFrequency="30" IsSnapToTickEnabled="True" />

            <TextBlock Text="{Binding MinFileSizeMb, StringFormat='Minimum file size to include: {0} MB'}" Margin="0,16,0,4" />
            <Slider Value="{Binding MinFileSizeMb}" Minimum="1" Maximum="500" Width="400"
                    HorizontalAlignment="Left" TickFrequency="10" />

            <!-- Excluded Paths -->
            <TextBlock Text="Excluded Paths" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,8" />
            <TextBlock Text="These paths will be skipped during Deep Scan." Opacity="0.6" Margin="0,0,0,8" FontSize="12" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox Text="{Binding NewExcludedPath, UpdateSourceTrigger=PropertyChanged}"
                         ui:ControlHelper.PlaceholderText="C:\path\to\exclude"
                         Width="350" Margin="0,0,8,0" />
                <Button Content="Add" Command="{Binding AddExcludedPathCommand}" Padding="16,6" />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding ExcludedPaths}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                CornerRadius="4" Padding="12,6" Margin="0,0,0,4">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="&#xE711;"
                                        FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="10"
                                        Command="{Binding DataContext.RemoveExcludedPathCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Padding="6,2" Background="Transparent" BorderThickness="0" />
                                <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
